// generator config.
generator client {
  provider = "prisma-client-js"
}

// db connection.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// routes table. base data.
model Route {
  id              String  @id @default(uuid())
  routeId         String  @map("route_id")
  vesselType      String  @map("vessel_type")
  fuelType        String  @map("fuel_type")
  year            Int
  ghgIntensity    Float   @map("ghg_intensity")
  fuelConsumption Float   @map("fuel_consumption")
  distance        Float
  totalEmissions  Float   @map("total_emissions")
  isBaseline      Boolean @default(false) @map("is_baseline")

  @@map("routes")
}

// computed cb records.
model ShipCompliance {
  id        String @id @default(uuid())
  shipId    String @map("ship_id")
  year      Int
  cbGco2eq  Float  @map("cb_gco2eq")

  @@unique([shipId, year])
  @@map("ship_compliance")
}

// banked surplus ledger.
model BankEntry {
  id           String @id @default(uuid())
  shipId       String @map("ship_id")
  year         Int
  amountGco2eq Float  @map("amount_gco2eq")

  @@map("bank_entries")
}

// pool registry.
model Pool {
  id        String       @id @default(uuid())
  year      Int
  createdAt DateTime     @default(now()) @map("created_at")
  members   PoolMember[]

  @@map("pools")
}

// pool allocations.
model PoolMember {
  id       String @id @default(uuid())
  poolId   String @map("pool_id")
  shipId   String @map("ship_id")
  cbBefore Float  @map("cb_before")
  cbAfter  Float  @map("cb_after")

  pool Pool @relation(fields: [poolId], references: [id])

  @@map("pool_members")
}